{
  "expo": {
    "name": "Vickins Business OS",
    "slug": "vickins-business-os",
    "scheme": "vickinsbos",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0B1220"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      "expo-secure-store",
      [
        "expo-sqlite",
        {
          "enableFTS": true
        }
      ]
    ]
  }
}
